{
  "expo": {
    "name": "DoceGestar",
    "slug": "doce-gestar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "docegestar",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbf9f5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.docegestar.app"
    },
    "android": {
      "package": "com.docegestar.app",
      "adaptiveIcon": {
        "backgroundColor": "#fbf9f5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-image-picker",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#b30064"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9890d16e-0012-42b7-a29d-1c3adb521f56"
      }
    }
  }
}
